<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.24.xsd">

    <!-- Таблица t_animals -->
    <changeSet id="1" author="undy11203">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="t_animals"/>
            </not>
        </preConditions>
        <createTable tableName="t_animals" remarks="Виды животных">
            <column name="id" type="BIGSERIAL">
                <constraints nullable="false" unique="true" primaryKey="true"/>
            </column>
            <column name="name" type="VARCHAR(64)" remarks="Название вида">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="2" author="undy11203">
        <preConditions onFail="MARK_RAN">
            <not>
                <indexExists indexName="t_animals_name_idx" tableName="t_animals"/>
            </not>
        </preConditions>
        <createIndex indexName="t_animals_name_idx" tableName="t_animals">
            <column name="name"/>
        </createIndex>
    </changeSet>

    <!-- Таблица t_placement_goals -->
    <changeSet id="3" author="undy11203">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="t_placement_goals"/>
            </not>
        </preConditions>
        <createTable tableName="t_placement_goals" remarks="Цели размещения на площадке">
            <column name="id" type="BIGSERIAL">
                <constraints nullable="false" unique="true" primaryKey="true"/>
            </column>
            <column name="goal" type="VARCHAR(32)">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="4" author="undy11203">
        <preConditions onFail="MARK_RAN">
            <not>
                <indexExists indexName="t_placement_goals_goal_idx" tableName="t_placement_goals"/>
            </not>
        </preConditions>
        <createIndex indexName="t_placement_goals_goal_idx" tableName="t_placement_goals">
            <column name="goal"/>
        </createIndex>
    </changeSet>

    <!-- Таблица t_animals_cards_status -->
    <changeSet id="5" author="undy11203">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="t_animals_cards_status"/>
            </not>
        </preConditions>
        <createTable tableName="t_animals_cards_status" remarks="Статус карточки животного">
            <column name="id" type="BIGSERIAL">
                <constraints nullable="false" unique="true" primaryKey="true"/>
            </column>
            <column name="name" type="VARCHAR(32)" remarks="Наименование статуса">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="6" author="undy11203">
        <preConditions onFail="MARK_RAN">
            <not>
                <indexExists indexName="t_animals_cards_status_name_idx" tableName="t_animals_cards_status"/>
            </not>
        </preConditions>
        <createIndex indexName="t_animals_cards_status_name_idx" tableName="t_animals_cards_status">
            <column name="name"/>
        </createIndex>
    </changeSet>

    <!-- Таблица t_animals_cards -->
    <changeSet id="7" author="undy11203">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="t_animals_cards"/>
            </not>
            <tableExists tableName="t_users"/>
            <tableExists tableName="t_animals"/>
            <tableExists tableName="t_placement_goals"/>
            <tableExists tableName="t_animals_cards_status"/>
        </preConditions>
        <createTable tableName="t_animals_cards" remarks="Карточка животного">
            <column name="id" type="BIGSERIAL">
                <constraints nullable="false" unique="true" primaryKey="true"/>
            </column>
            <column name="id_user" type="BIGINT" remarks="Пользователь">
                <constraints nullable="false"/>
            </column>
            <column name="name" type="VARCHAR(64)" remarks="Кличка">
                <constraints nullable="false"/>
            </column>
            <column name="id_animal" type="BIGINT" remarks="Вид животного">
                <constraints nullable="false"/>
            </column>
            <column name="breed" type="VARCHAR(64)" remarks="Порода"/>
            <column name="gender" type="VARCHAR(1)" remarks="Пол">
                <constraints nullable="false"/>
            </column>
            <column name="birthdate" type="DATE" remarks="Дата рождения">
                <constraints nullable="false"/>
            </column>
            <column name="weight" type="DECIMAL(6,1)" remarks="Вес в кг"/>
            <column name="color" type="VARCHAR(200)" remarks="Окрас">
                <constraints nullable="false"/>
            </column>
            <column name="genetic_diseases" type="VARCHAR(2000)" remarks="Наследственные заболевания">
                <constraints nullable="false"/>
            </column>
            <column name="description" type="VARCHAR(2000)" remarks="Описание"/>
            <column name="id_goal" type="BIGINT" remarks="Цель размещения">
                <constraints nullable="false"/>
            </column>
            <column name="cost" type="DECIMAL(10,2)"/>
            <column name="created" type="TIMESTAMPTZ" remarks="Дата создания объявления">
                <constraints nullable="false"/>
            </column>
            <column name="updated" type="TIMESTAMPTZ" remarks="Дата редактирования объявления">
                <constraints nullable="false"/>
            </column>
            <column name="id_status" type="BIGINT"/>
        </createTable>
    </changeSet>

    <!-- Check constraint для gender -->
    <changeSet id="8" author="undy11203">
        <preConditions onFail="MARK_RAN">
            <not>
                <sqlCheck expectedResult="0">
                    SELECT COUNT(*) FROM information_schema.table_constraints
                    WHERE table_name = 't_animals_cards' AND constraint_name = 't_animals_cards_gender_check_is_vaild'
                </sqlCheck>
            </not>
        </preConditions>
        <sql>ALTER TABLE t_animals_cards ADD CONSTRAINT t_animals_cards_gender_check_is_vaild CHECK (gender IN ('F', 'M'))</sql>
    </changeSet>

    <changeSet id="9" author="undy11203">
        <preConditions onFail="MARK_RAN">
            <not>
                <indexExists indexName="t_animals_cards_id_user_idx" tableName="t_animals_cards"/>
            </not>
        </preConditions>
        <createIndex indexName="t_animals_cards_id_user_idx" tableName="t_animals_cards">
            <column name="id_user"/>
        </createIndex>
    </changeSet>

    <changeSet id="10" author="undy11203">
        <preConditions onFail="MARK_RAN">
            <not>
                <indexExists indexName="t_animals_cards_name_idx" tableName="t_animals_cards"/>
            </not>
        </preConditions>
        <createIndex indexName="t_animals_cards_name_idx" tableName="t_animals_cards">
            <column name="name"/>
        </createIndex>
    </changeSet>

    <changeSet id="11" author="undy11203">
        <preConditions onFail="MARK_RAN">
            <not>
                <indexExists indexName="t_animals_cards_id_animal_idx" tableName="t_animals_cards"/>
            </not>
        </preConditions>
        <createIndex indexName="t_animals_cards_id_animal_idx" tableName="t_animals_cards">
            <column name="id_animal"/>
        </createIndex>
    </changeSet>

    <changeSet id="12" author="undy11203">
        <preConditions onFail="MARK_RAN">
            <not>
                <indexExists indexName="t_animals_cards_breed_idx" tableName="t_animals_cards"/>
            </not>
        </preConditions>
        <createIndex indexName="t_animals_cards_breed_idx" tableName="t_animals_cards">
            <column name="breed"/>
        </createIndex>
    </changeSet>

    <changeSet id="13" author="undy11203">
        <preConditions onFail="MARK_RAN">
            <not>
                <indexExists indexName="t_animals_cards_id_goal_idx" tableName="t_animals_cards"/>
            </not>
        </preConditions>
        <createIndex indexName="t_animals_cards_id_goal_idx" tableName="t_animals_cards">
            <column name="id_goal"/>
        </createIndex>
    </changeSet>

    <changeSet id="14" author="undy11203">
        <preConditions onFail="MARK_RAN">
            <not>
                <indexExists indexName="t_animals_cards_created_idx" tableName="t_animals_cards"/>
            </not>
        </preConditions>
        <createIndex indexName="t_animals_cards_created_idx" tableName="t_animals_cards">
            <column name="created"/>
        </createIndex>
    </changeSet>

    <changeSet id="15" author="undy11203">
        <preConditions onFail="MARK_RAN">
            <not>
                <indexExists indexName="t_animals_cards_birthdate_idx" tableName="t_animals_cards"/>
            </not>
        </preConditions>
        <createIndex indexName="t_animals_cards_birthdate_idx" tableName="t_animals_cards">
            <column name="birthdate"/>
        </createIndex>
    </changeSet>

    <changeSet id="16" author="undy11203">
        <preConditions onFail="MARK_RAN">
            <not>
                <foreignKeyConstraintExists foreignKeyTableName="t_animals_cards" foreignKeyName="fk_t_animals_cards_id_user_t_users_id"/>
            </not>
        </preConditions>
        <addForeignKeyConstraint baseTableName="t_animals_cards"
                                 baseColumnNames="id_user"
                                 constraintName="fk_t_animals_cards_id_user_t_users_id"
                                 referencedTableName="t_users"
                                 referencedColumnNames="id"/>
    </changeSet>

    <changeSet id="17" author="undy11203">
        <preConditions onFail="MARK_RAN">
            <not>
                <foreignKeyConstraintExists foreignKeyTableName="t_animals_cards" foreignKeyName="fk_t_animals_cards_id_animal_t_animals_id"/>
            </not>
        </preConditions>
        <addForeignKeyConstraint baseTableName="t_animals_cards"
                                 baseColumnNames="id_animal"
                                 constraintName="fk_t_animals_cards_id_animal_t_animals_id"
                                 referencedTableName="t_animals"
                                 referencedColumnNames="id"/>
    </changeSet>

    <changeSet id="18" author="undy11203">
        <preConditions onFail="MARK_RAN">
            <not>
                <foreignKeyConstraintExists foreignKeyTableName="t_animals_cards" foreignKeyName="fk_t_animals_cards_id_goal_t_placement_goals_id"/>
            </not>
        </preConditions>
        <addForeignKeyConstraint baseTableName="t_animals_cards"
                                 baseColumnNames="id_goal"
                                 constraintName="fk_t_animals_cards_id_goal_t_placement_goals_id"
                                 referencedTableName="t_placement_goals"
                                 referencedColumnNames="id"/>
    </changeSet>

    <changeSet id="19" author="undy11203">
        <preConditions onFail="MARK_RAN">
            <not>
                <foreignKeyConstraintExists foreignKeyTableName="t_animals_cards" foreignKeyName="fk_t_animals_cards_id_status_t_animals_cards_status_id"/>
            </not>
        </preConditions>
        <addForeignKeyConstraint baseTableName="t_animals_cards"
                                 baseColumnNames="id_status"
                                 constraintName="fk_t_animals_cards_id_status_t_animals_cards_status_id"
                                 referencedTableName="t_animals_cards_status"
                                 referencedColumnNames="id"/>
    </changeSet>

</databaseChangeLog>
