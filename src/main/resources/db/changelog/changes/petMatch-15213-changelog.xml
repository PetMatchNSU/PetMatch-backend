<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.31.xsd"
        objectQuotingStrategy="QUOTE_ONLY_RESERVED_WORDS">
    <changeSet id="15213-1" author="bel9sh">
        <createTable tableName="t_authorities">
            <column autoIncrement="true" name="id" type="BIGINT">
                <constraints nullable="false" primaryKey="true" primaryKeyName="pk_t_authorities"/>
            </column>
            <column name="name" type="VARCHAR(64)">
                <constraints nullable="false"/>
            </column>
            <column name="description" type="VARCHAR(256)">
                <constraints nullable="false"/>
            </column>
            <column name="id_authority" type="BIGINT">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>
    <changeSet id="15213-2" author="bel9sh">
        <addUniqueConstraint columnNames="description" constraintName="uc_t_authorities_description"
                             tableName="t_authorities"/>
    </changeSet>
    <changeSet id="15213-3" author="bel9sh">
        <addUniqueConstraint columnNames="name" constraintName="uc_t_authorities_name" tableName="t_authorities"/>
    </changeSet>
    <changeSet id="15213-4" author="bel9sh">
        <addForeignKeyConstraint baseColumnNames="id_authority" baseTableName="t_authorities"
                                 constraintName="FK_T_AUTHORITIES_ON_ID_AUTHORITY" referencedColumnNames="id"
                                 referencedTableName="t_users"/>
    </changeSet>

    <changeSet id="15213-5" author="bel9sh">
        <addColumn tableName="t_users">
            <column name="is_email_verified" type="boolean"/>
        </addColumn>
    </changeSet>

</databaseChangeLog>