<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.24.xsd">

    <changeSet id="1" author="kurdyukovda">
        <loadData tableName="t_regions"
                  file="db/changelog/data/regions_cities.csv"
                  relativeToChangelogFile="false">
            <column name="region" header="region" type="STRING"/>
            <column name="city" header="city" type="STRING"/>
        </loadData>
    </changeSet>

    <changeSet id="2" author="kurdyukovda">
        <preConditions onFail="MARK_RAN">
            <sqlCheck expectedResult="0">
                SELECT COUNT(*) FROM t_contacts_types WHERE name = 'PHONE'
            </sqlCheck>
        </preConditions>
        <insert tableName="t_contacts_types">
            <column name="name" value="PHONE"/>
        </insert>
    </changeSet>

    <changeSet id="3" author="kurdyukovda">
        <preConditions onFail="MARK_RAN">
            <sqlCheck expectedResult="0">
                SELECT COUNT(*) FROM t_contacts_types WHERE name = 'EMAIL'
            </sqlCheck>
        </preConditions>
        <insert tableName="t_contacts_types">
            <column name="name" value="EMAIL"/>
        </insert>
    </changeSet>

    <changeSet id="4" author="kurdyukovda">
        <preConditions onFail="MARK_RAN">
            <sqlCheck expectedResult="0">
                SELECT COUNT(*) FROM t_contacts_types WHERE name = 'TELEGRAM'
            </sqlCheck>
        </preConditions>
        <insert tableName="t_contacts_types">
            <column name="name" value="TELEGRAM"/>
        </insert>
    </changeSet>

    <changeSet id="5" author="kurdyukovda">
        <preConditions onFail="MARK_RAN">
            <sqlCheck expectedResult="0">
                SELECT COUNT(*) FROM t_contacts_types WHERE name = 'VK'
            </sqlCheck>
        </preConditions>
        <insert tableName="t_contacts_types">
            <column name="name" value="VK"/>
        </insert>
    </changeSet>

    <changeSet id="6" author="kurdyukovda">
        <preConditions onFail="MARK_RAN">
            <sqlCheck expectedResult="0">
                SELECT COUNT(*) FROM t_statuses WHERE name = 'BLOCKED'
            </sqlCheck>
        </preConditions>
        <insert tableName="t_statuses">
            <column name="name" value="BLOCKED"/>
        </insert>
    </changeSet>

    <changeSet id="7" author="kurdyukovda">
        <preConditions onFail="MARK_RAN">
            <sqlCheck expectedResult="0">
                SELECT COUNT(*) FROM t_statuses WHERE name = 'ACTIVE'
            </sqlCheck>
        </preConditions>
        <insert tableName="t_statuses">
            <column name="name" value="ACTIVE"/>
        </insert>
    </changeSet>

    <changeSet id="8" author="kurdyukovda">
        <preConditions onFail="MARK_RAN">
            <sqlCheck expectedResult="NO">
                SELECT is_nullable
                FROM information_schema.columns
                WHERE table_name = 't_animals_cards'
                AND column_name = 'id_animal'
            </sqlCheck>
        </preConditions>
        <dropNotNullConstraint
                tableName="t_animals_cards"
                columnName="id_animal"
                columnDataType="BIGINT"/>
    </changeSet>

</databaseChangeLog>