<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.24.xsd">

    <changeSet id="1" author="undy11203">
        <preConditions onFail="MARK_RAN">
            <and>
                <columnExists tableName="t_animals_cards_files" columnName="id_type"/>
                <sqlCheck expectedResult="1">
                    SELECT CASE WHEN is_nullable = 'NO' THEN 1 ELSE 0 END
                    FROM information_schema.columns
                    WHERE table_name = 't_animals_cards_files'
                    AND column_name = 'id_type'
                </sqlCheck>
            </and>
        </preConditions>

        <!-- Сначала удаляем foreign key constraint -->
        <dropForeignKeyConstraint baseTableName="t_animals_cards_files"
                                 constraintName="fk_t_animals_cards_files_id_type_t_animals_cards_files_types_id"/>
        <!-- Затем убираем NOT NULL constraint -->
        <dropNotNullConstraint tableName="t_animals_cards_files" columnName="id_type"/>
        <!-- И создаем foreign key заново как nullable -->
        <addForeignKeyConstraint baseTableName="t_animals_cards_files"
                                 baseColumnNames="id_type"
                                 constraintName="fk_t_animals_cards_files_id_type_t_animals_cards_files_types_id"
                                 referencedTableName="t_animals_cards_files_types"
                                 referencedColumnNames="id"/>
    </changeSet>

</databaseChangeLog>
