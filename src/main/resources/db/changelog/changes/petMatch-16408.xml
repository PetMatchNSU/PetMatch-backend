<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.24.xsd">

    <!-- Увеличение максимальной длины ФИО до 64 символов -->
    <changeSet id="14593-1" author="fix">
        <modifyDataType tableName="t_users" columnName="first_name" newDataType="VARCHAR(64)"/>
    </changeSet>

    <changeSet id="14593-2" author="fix">
        <modifyDataType tableName="t_users" columnName="second_name" newDataType="VARCHAR(64)"/>
    </changeSet>

    <changeSet id="14593-3" author="fix">
        <modifyDataType tableName="t_users" columnName="last_name" newDataType="VARCHAR(64)"/>
    </changeSet>

</databaseChangeLog>
